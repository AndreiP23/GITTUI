{
  "GitHub": {
    "PageSize": 100,
    "PageCount": 1,
    "HistoryDays": 14,
    "DebounceDelayMs": 300
  },
  "Cache": {
    "RepositoriesTtlSeconds": 300,
    "ActivityTtlSeconds": 60
  },
  "AutoRefresh": {
    "Enabled": true,
    "IntervalSeconds": 120
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/gittui-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ]
  }
}
